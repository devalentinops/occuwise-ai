{
  "dataset": "aptos",
  "task": "classification",
  "modality": "fundus",
  "num_classes": 5,
  "class_names": [
    "No DR",
    "Mild",
    "Moderate",
    "Severe",
    "Proliferative"
  ],
  "image_size": 512,
  "normalization": {
    "mean": [
      0.485,
      0.456,
      0.406
    ],
    "std": [
      0.229,
      0.224,
      0.225
    ]
  },
  "primary_metric": "quadratic_kappa",
  "checkpoint": "models/aptos/resnet50/best.ckpt",
  "arch": "resnet50",
  "intended_use": "Clinical decision support (screening triage). NOT a standalone diagnosis.",
  "limitations": "Trained on public datasets; validate on local population before deployment."
}